DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DBNAME"
NEXT_PUBLIC_SITE_URL=https://www.mozi.com.ua

# Canonical root domain without subdomain (used to normalize www and avoid duplicate hosts).
# Keep city subdomains intact (e.g. kyiv.mozi.com.ua).
# Example: mozi.com.ua
NEXT_PUBLIC_CANONICAL_DOMAIN=mozi.com.ua

# Optional: share admin/site session cookie across subdomains.
# Example: .mozi.com.ua
AUTH_COOKIE_DOMAIN=